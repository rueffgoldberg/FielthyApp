    <queries>
        <package android:name="com.google.android.apps.healthdata" />
    </queries>

    <application
        android:name=".FieltyApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FielthyApps"
        tools:targetApi="31">
        <activity
            android:name=".Feature.Physical.PanduanBalkeActivity"
            android:exported="false" />
        <activity
            android:name=".Feature.Physical.Panduan6MWTActivity"
            android:exported="false" />
        <activity
            android:name=".Feature.Physical.Panduan6MWT"
            android:exported="false" />

        <service
            android:name=".Feature.Physical.TrackingService"
            android:exported="false"
