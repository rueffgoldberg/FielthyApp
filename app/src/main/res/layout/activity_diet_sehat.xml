<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/white"
    tools:context=".Feature.Nutrition.DietSehatActivity">

    <LinearLayout
        android:id="@+id/header_diet_sehat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <!-- Header Atas -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="40dp">

            <ImageView
                android:id="@+id/iV_kembali"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:padding="6dp"
                android:src="@drawable/ic_backward"
                app:tint="@color/black"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="@font/poppins_extrabold"
                android:text="Tips Diet Sehat"
                android:textColor="@color/black"
                android:textSize="22sp"/>
        </RelativeLayout>

        <TextView
            android:id="@+id/tv_subtitle_diet_sehat"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/poppins_med"
            android:textAlignment="center"
            android:text="Panduan pola makan untuk mencapai tujuan berat badan Anda secara sehat"
            android:textColor="@color/black"
            android:textSize="14sp" />

    </LinearLayout>

    <ScrollView
    android:id="@+id/scroll_diet_sehat"
    android:layout_width="match_parent"
    android:layout_height="0dp"
    android:layout_marginTop="14dp"
    android:layout_marginBottom="2dp"
    android:fillViewport="true"
    android:overScrollMode="never"
    app:layout_constraintTop_toBottomOf="@id/header_diet_sehat"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="20dp">

            <!-- TIPS MENURUNKAN BERAT BADAN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_outline_green"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📉 Tips Menurunkan Berat Badan"
                        android:textColor="@color/tab"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="17sp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="18dp"
                        android:text="✓ Kurangi konsumsi minuman manis dan makanan tinggi gula"
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ Perbanyak konsumsi sayur dan buah setiap hari"
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ Pilih sumber protein rendah lemak."
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ Batasi makanan tinggi lemak dan gorengan."
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ Lakukan aktivitas fisik minimal 30 menit per hari."
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:background="@drawable/bg_item_white"
                        android:padding="10dp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"
                        android:justificationMode="inter_word"
                        android:text="Penurunan berat badan yang sehat adalah 0,5–1 kg per minggu."/>
                </LinearLayout>
            </LinearLayout>

            <!-- TIPS MEMPERTAHANKAN -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_outline_green"
                android:layout_marginTop="15dp"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📋 Tips Mempertahankan Berat Badan"
                        android:textColor="@color/blue"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="17sp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ Konsumsi makanan beragam sesuai prinsip Isi Piringku."
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ Jaga porsi makan sesuai kebutuhan kalori."
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ Tetap aktif bergerak dan berolahraga."
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ Batasi makanan ultra-proses dan tinggi gula."
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ Tidur cukup dan kelola stres dengan baik."
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"/>

                </LinearLayout>
            </LinearLayout>

            <!-- TIPS MENAMBAH -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_outline_green"
                android:layout_marginTop="15dp"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📈 Tips Menambah Berat Badan"
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="17sp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="✓ Tambah porsi makan secara bertahap."
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ Konsumsi sumber protein berkualitas."
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ Tambahkan camilan sehat di antara waktu makan."
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ Jangan melewatkan sarapan."
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ Lakukan latihan kekuatan untuk membantu pertumbuhan otot."
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"/>

                </LinearLayout>
            </LinearLayout>

            <!-- YANG PERLU DIHINDARI -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_outline_green"
                android:layout_marginTop="15dp"
                android:elevation="2dp"
                android:orientation="vertical"
                android:padding="5dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="❌ Yang Perlu Dihindari"
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="17sp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="✓ Melewatkan waktu makan."
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ Diet sangat rendah kalori."
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ Mengonsumsi minuman manis berlebihan."
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ Mengandalkan suplemen pelangsing."
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="12dp"
                        android:background="#EEEEEE"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="✓ Menghindari kelompok makanan tertentu tanpa alasan medis."
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="13sp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- INGAT -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:background="@drawable/bg_item_white"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⭐ Ingat!"
                    android:textColor="@color/orange"
                    android:fontFamily="@font/poppins_bold"
                    android:textSize="16sp"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:text="Perubahan berat badan yang sehat memerlukan waktu dan konsistensi. Fokuslah pada pola makan seimbang dan gaya hidup aktif, bukan hasil yang instan."
                    android:textColor="@color/black"
                    android:fontFamily="@font/poppins_reg"
                    android:textSize="13sp"
                    android:justificationMode="inter_word"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>