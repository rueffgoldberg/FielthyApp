<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".Feature.Nutrition.HasilBMRActivity"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/LinearLayout11"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="5dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Header atas -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="40dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="@font/poppins_bold"
                android:text="Kategori"
                android:textColor="@color/black"
                android:textSize="20sp" />
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="1dp"
            android:fontFamily="@font/poppins_bold"
            android:text="Nutrition"
            android:textColor="@color/black"
            android:textSize="18sp" />

        <!-- Progress -->
        <LinearLayout
            android:id="@+id/progress_nutrition"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="7dp"
            android:gravity="top|center_horizontal"
            android:orientation="horizontal">

            <!-- Step 1 -->
            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <View
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:background="@drawable/circle_active" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:fontFamily="@font/poppins_med"
                    android:gravity="center"
                    android:text="Nutrition"
                    android:textColor="@color/grey"
                    android:textSize="10sp" />

            </LinearLayout>

            <!-- Garis -->
            <View
                android:layout_width="55dp"
                android:layout_height="1.5dp"
                android:layout_marginTop="13dp"
                android:background="@color/blue" />

            <!-- Step 2 -->
            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <View
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:background="@drawable/circle_active" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:fontFamily="@font/poppins_med"
                    android:gravity="center"
                    android:text="Form \nPemeriksaan"
                    android:textColor="@color/grey"
                    android:textSize="10sp" />
            </LinearLayout>

            <!--Garis 2-->
            <View
                android:layout_width="55dp"
                android:layout_height="1.5dp"
                android:layout_marginTop="13dp"
                android:background="@color/blue" />

            <!--Step 3 -->
            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <View
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:background="@drawable/circle_active" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:fontFamily="@font/poppins_med"
                    android:gravity="center"
                    android:text="Hasil \nPemeriksaan"
                    android:textColor="@color/grey"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/white"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="17dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/LinearLayout11"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="25dp"
            android:paddingEnd="25dp"
            android:paddingBottom="30dp">

            <!--DATA PERHITUNGAN-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:background="@drawable/bg_white_stroke_blue"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Data Perhitungan"
                    android:scrollbarSize="18sp"
                    android:textColor="@color/always_black"
                    android:fontFamily="@font/poppins_bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Data yang Anda masukkan digunakan untuk menghitung BMR dan TDEE"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins_reg"
                    android:textColor="@color/always_black"
                    android:layout_marginTop="2dp"/>

                <!--Gender-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_person"
                        app:tint="@color/blue"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Jenis Kelamin"
                        android:fontFamily="@font/poppins_med"
                        android:textColor="@color/always_black"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_gender"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Laki-laki"
                        android:textColor="@color/always_black"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_bold"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:background="#EAEAEA"/>

                <!--UMUR-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_calendar"
                        app:tint="@color/blue"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Umur"
                        android:fontFamily="@font/poppins_med"
                        android:textColor="@color/always_black"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_umur"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="20 Tahun"
                        android:textColor="@color/always_black"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_bold"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:background="#EAEAEA"/>

                <!--Berat Badan-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_monitor_scale"
                        app:tint="@color/blue"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Berat Badan"
                        android:fontFamily="@font/poppins_med"
                        android:textColor="@color/always_black"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_berat"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="60 kg"
                        android:textColor="@color/always_black"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_bold"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:background="#EAEAEA"/>

                <!-- Tinggi Badan -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_arrow_right"
                        app:tint="@color/blue"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Tinggi Badan"
                        android:fontFamily="@font/poppins_med"
                        android:textColor="@color/always_black"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_tinggi"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="170 cm"
                        android:textColor="@color/always_black"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_bold"/>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="8dp"
                    android:background="#EAEAEA"/>

                <!-- Aktivitas -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_foot"
                        app:tint="@color/blue"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:text="Tingkat Aktivitas"
                        android:fontFamily="@font/poppins_med"
                        android:textColor="@color/always_black"
                        android:textSize="12sp"/>

                    <TextView
                        android:id="@+id/tv_aktivitas_detail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Ringan (1.375)"
                        android:textColor="@color/always_black"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_bold"/>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_white_stroke_blue"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:background="@drawable/circle_dark"
                        android:padding="15dp"
                        android:src="@drawable/ic_kalori_hm"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="BMR"
                            android:textColor="@color/always_black"
                            android:textSize="20sp"
                            android:fontFamily="@font/poppins_bold"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_bmr"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="1.788"
                                android:textColor="@color/blue"
                                android:textSize="22sp"
                                android:fontFamily="@font/poppins_bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="kkal/hari"
                                android:textColor="@color/always_black"
                                android:textSize="16sp"
                                android:fontFamily="@font/poppins_bold"/>
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="#D9D9D9"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Energi minimum yang dibutuhkan tubuh untuk menjalankan fungsi dasar saat beristirahat."
                    android:textColor="@color/always_black"
                    android:textSize="11sp"
                    android:fontFamily="@font/poppins_reg"/>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_white_stroke_blue"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="70dp"
                        android:layout_height="70dp"
                        android:background="@drawable/circle_dark"
                        android:padding="15dp"
                        android:src="@drawable/ic_kalori_hm"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="16dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kalori Harian (TDEE)"
                            android:textColor="@color/always_black"
                            android:textSize="20sp"
                            android:fontFamily="@font/poppins_bold"/>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <TextView
                                android:id="@+id/tv_tdee"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="2.456"
                                android:textColor="@color/blue"
                                android:textSize="22sp"
                                android:fontFamily="@font/poppins_bold"/>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginStart="4dp"
                                android:text="kkal/hari"
                                android:textColor="@color/always_black"
                                android:textSize="16sp"
                                android:fontFamily="@font/poppins_bold"/>
                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="#D9D9D9"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Aktivitas -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="35dp"
                            android:layout_height="35dp"
                            android:background="@drawable/circle_dark"
                            android:padding="8dp"
                            android:src="@drawable/ic_foot"
                            app:tint="@color/black"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Aktivitas"
                            android:textSize="10sp"
                            android:fontFamily="@font/poppins_reg"
                            android:textColor="@color/always_black"/>

                        <TextView
                            android:id="@+id/tv_aktivitas"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Ringan"
                            android:textSize="11sp"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/always_black"/>
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="50dp"
                        android:background="#D9D9D9"/>

                    <!-- Faktor Aktivitas -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <ImageView
                            android:layout_width="35dp"
                            android:layout_height="35dp"
                            android:background="@drawable/circle_dark"
                            android:padding="8dp"
                            app:tint="@color/black"
                            android:src="@drawable/ic_foot"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Faktor Aktivitas"
                            android:textSize="10sp"
                            android:fontFamily="@font/poppins_reg"
                            android:textColor="@color/always_black"/>

                        <TextView
                            android:id="@+id/tv_faktor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="1.375"
                            android:textSize="11sp"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/always_black"/>
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!--Rekomendasi Target Harian-->
            <LinearLayout
                android:id="@+id/rekomendasi_kalori"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="15dp"
                android:background="@drawable/bg_white_stroke_blue"
                android:orientation="vertical"
                android:padding="16dp">

                <!--Header-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_kalori_hm"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rekomendasi Target Kalori"
                            android:textColor="@color/always_black"
                            android:textSize="18sp"
                            android:fontFamily="@font/poppins_bold"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pilih sesuai tujuanmu"
                            android:fontFamily="@font/poppins_reg"
                            android:textColor="@color/always_black"
                            android:textSize="11sp"/>
                    </LinearLayout>
                </LinearLayout>

                <!--Turun BB-->

                <!--Normal-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_btn_green"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_monitor_scale"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pertahankan Berat Badan"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/always_black"/>

                        <TextView
                            android:id="@+id/tv_normal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2456 kkal/hari"
                            android:textSize="22sp"
                            android:textColor="@color/always_black"
                            android:fontFamily="@font/poppins_bold"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Maintenance"
                        android:textSize="10sp"
                        android:fontFamily="@font/poppins_reg"
                        android:textColor="@color/always_black"
                        android:background="@drawable/bg_badge_white"
                        android:padding="8dp"/>
                </LinearLayout>

                <!-- NAIK BB -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_btn_red"
                    android:gravity="center_vertical"
                    android:padding="14dp">

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_arrow_down" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins_bold"
                                android:text="Turun Berat Badan"
                                android:textColor="@color/always_black" />

                            <TextView
                                android:id="@+id/tV_turun"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/poppins_bold"
                                android:text="1965 kkal/hari"
                                android:textColor="@color/always_black"
                                android:textSize="22sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_badge_white"
                        android:fontFamily="@font/poppins_reg"
                        android:paddingStart="10dp"
                        android:paddingTop="6dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="6dp"
                        android:text="- 500 kkal"
                        android:textColor="@color/always_black"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_btn_grey"
                    android:padding="14dp"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:src="@drawable/ic_person"/>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Naik Berat Badan"
                            android:textColor="@color/always_black"
                            android:fontFamily="@font/poppins_bold"/>

                        <TextView
                            android:id="@+id/tv_naik"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2956 kkal/hari"
                            android:textSize="22sp"
                            android:textColor="@color/always_black"
                            android:fontFamily="@font/poppins_bold"/>
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ 500 kkal"
                        android:textSize="10sp"
                        android:textColor="@color/always_black"
                        android:fontFamily="@font/poppins_reg"
                        android:background="@drawable/bg_badge_white"
                        android:padding="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Cara Mencapai Target -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="Bagaimana cara mencapai target kalori ini?"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_bold"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <!-- Makanan Sehat -->
                <LinearLayout
                    android:id="@+id/ll_makanan_sehat"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_white_stroke_blue"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/circle_dark"
                        android:padding="12dp"
                        android:src="@drawable/img_nutrition2"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:minLines="2"
                        android:text="Makanan Sehat"
                        android:textColor="@color/tab"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_bold"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:minLines="3"
                        android:text="Panduan menu sehat harian sesuai target kalori"
                        android:textColor="@color/always_black"
                        android:textSize="10sp"
                        android:fontFamily="@font/poppins_reg"/>
                </LinearLayout>

                <!-- Diet Plan -->
                <LinearLayout
                    android:id="@+id/ll_diet_plan"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_white_stroke_orange"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="12dp">

                    <ImageView
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:background="@drawable/circle_dark"
                        android:padding="12dp"
                        android:src="@drawable/ic_kalori_hm"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:gravity="center"
                        android:minLines="2"
                        android:text="Diet Plan"
                        android:textColor="@color/orange"
                        android:textSize="15sp"
                        android:fontFamily="@font/poppins_bold"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:minLines="3"
                        android:text="Contoh pola makan sesuai target kalori dan tujuanmu"
                        android:textColor="@color/always_black"
                        android:textSize="10sp"
                        android:fontFamily="@font/poppins_reg"/>
                </LinearLayout>

            </LinearLayout>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btn_selesai"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="24dp"
                android:background="@drawable/bg_btn_green_new"
                android:fontFamily="@font/poppins_bold"
                android:text="Selesai"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="15sp" />

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>