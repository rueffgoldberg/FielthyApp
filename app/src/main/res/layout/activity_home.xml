<?xml version="1.0" encoding="UTF-8" ?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/white"
    tools:context=".HomeActivity">

    <!--Header Section-->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:layout_marginTop="5dp"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tV_profile"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selamat pagi, User!"
                android:fontFamily="@font/poppins_med"
                android:textSize="16sp"
                android:textColor="@color/black"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Jaga kesehatan Anda hari ini!^^"
                android:fontFamily="@font/poppins_reg"
                android:textSize="13sp"
                android:textColor="@color/black"/>
        </LinearLayout>

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/profile_image"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_marginStart="16dp"
            android:src="@drawable/ic_person"
            app:civ_border_color="@color/grey"
            app:civ_border_width="2dp"/>
    </LinearLayout>

    <!--Ringkasan Hari Ini-->
    <TextView
        android:id="@+id/tV_summary"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_marginTop="7dp"
        android:text="Ringkasan Hari Ini"
        android:fontFamily="@font/poppins_bold"
        android:textSize="15sp"
        android:textColor="@color/black"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_layout"/>

    <LinearLayout
        android:id="@+id/layout_summary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:baselineAligned="false"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tV_summary">

        <!-- Asupan Air -->
        <LinearLayout
            android:id="@+id/card_water"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="88dp"
            android:layout_weight="1"
            android:layout_marginEnd="5dp"
            android:background="@drawable/bg_summary"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/circle_dark"
                android:padding="8dp"
                android:src="@drawable/ic_gelas_kosong"
                app:tint="@color/grey" />

            <!-- Ubah tinggi garis jadi match_parent agar dinamis mengikuti tinggi card -->
            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"
                android:background="#B7DCD9" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_bold"
                    android:text="Asupan Air"
                    android:textColor="@color/tab"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="bottom">

                    <TextView
                        android:id="@+id/tV_home_water"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="5/8"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:maxLines="1"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="2dp"
                        android:fontFamily="@font/poppins_med"
                        android:text="Gelas"
                        android:textColor="@color/black"
                        android:textSize="9sp"
                        android:maxLines="1" />

                </LinearLayout>

                <TextView
                    android:id="@+id/tV_home_water_status"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_status_normal"
                    android:fontFamily="@font/poppins_bold"
                    android:gravity="center"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:text="62%"
                    android:textColor="@color/black"
                    android:textSize="10sp"
                    android:maxLines="1"/>
            </LinearLayout>
        </LinearLayout>

        <!-- Aktivitas -->
        <LinearLayout
            android:id="@+id/card_aktivitas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="88dp"
            android:layout_weight="1"
            android:layout_marginStart="5dp"
            android:background="@drawable/bg_summary"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackground"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:paddingTop="10dp"
            android:paddingBottom="10dp">

            <ImageView
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/circle_dark"
                android:padding="8dp"
                android:src="@drawable/ic_foot"
                app:tint="@color/black" />

            <View
                android:layout_width="1dp"
                android:layout_height="match_parent"
                android:layout_marginStart="6dp"
                android:layout_marginEnd="6dp"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"
                android:background="#B7DCD9" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/poppins_bold"
                    android:text="Aktivitas"
                    android:textColor="@color/tab"
                    android:textSize="11sp"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="bottom"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tV_home_step"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/poppins_extrabold"
                        android:text="10"
                        android:textColor="@color/black"
                        android:textSize="18sp"
                        android:maxLines="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:layout_marginBottom="2dp"
                        android:fontFamily="@font/poppins_med"
                        android:text="Langkah"
                        android:textColor="@color/black"
                        android:textSize="9sp"
                        android:maxLines="1"
                        android:ellipsize="end"/>
                </LinearLayout>

                <TextView
                    android:id="@+id/tV_home_step_status"
                    android:layout_width="wrap_content"
                    android:layout_height="22dp"
                    android:layout_marginTop="4dp"
                    android:background="@drawable/bg_py_rendah"
                    android:fontFamily="@font/poppins_bold"
                    android:gravity="center"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:text="Rendah"
                    android:textColor="@color/black"
                    android:textSize="10sp"
                    android:maxLines="1" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <View
        android:id="@+id/line1"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="10dp"
        android:background="@color/grey"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        app:layout_constraintTop_toBottomOf="@id/layout_summary"/>

    <View
        android:id="@+id/line2"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginTop="5dp"
        android:layout_marginStart="15dp"
        android:layout_marginEnd="15dp"
        android:background="@color/grey"
        app:layout_constraintTop_toBottomOf="@id/line1"/>

    <!--Title Section-->
    <TextView
        android:id="@+id/textiew6"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_marginTop="10dp"
        android:text="Our Menu"
        android:textColor="@color/black"
        android:fontFamily="@font/poppins_extrabold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/line2"/>

    <!--Scrollable Menu-->
    <ScrollView
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="17dp"
        android:fillViewport="true"
        app:layout_constraintTop_toBottomOf="@id/textiew6"
        app:layout_constraintBottom_toTopOf="@id/bottomnavigate"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            android:paddingBottom="20dp"
            android:gravity="center_horizontal"
            android:orientation="vertical">

            <!--Card med check-->
            <LinearLayout
                android:id="@+id/LL_medcheck"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:background="@drawable/bg_white_stroke_blue"
                android:gravity="center_vertical"
                android:padding="15dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Med Check"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="21sp"
                        android:textColor="@color/always_black"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:layout_marginTop="2dp"
                        android:text="Pantau kondisi tubuh Anda dari riwayat pemeriksaan terakhir kali dengan dokter"
                        android:textColor="@color/always_black"
                        android:fontFamily="@font/poppins_med"
                        android:textSize="10sp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginStart="16dp"
                    android:src="@drawable/img_medcheck"/>
            </LinearLayout>

            <!--Card Smoker-->
            <LinearLayout
                android:id="@+id/LL_smoker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_white_stroke_blue"
                android:gravity="center_vertical"
                android:padding="15dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/img_smoker_cess"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Smoker Cessation"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="@color/always_black"
                        android:textSize="21sp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Bantu kurangi dan hentikan kebiasaan merokok secara bertahap."
                        android:fontFamily="@font/poppins_med"
                        android:textColor="@color/always_black"
                        android:textSize="10sp"/>
                </LinearLayout>
            </LinearLayout>

            <!--Card Nutrition-->
            <LinearLayout
                android:id="@+id/LL_nutrition"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_white_stroke_blue"
                android:gravity="center_vertical"
                android:padding="15dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nutrition"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="@color/always_black"
                        android:textSize="21sp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/always_black"
                        android:fontFamily="@font/poppins_med"
                        android:text="Dalam fitur ini Anda bisa tau makanan dan minuman yang Anda konsumsi."
                        android:textSize="10sp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginStart="16dp"
                    android:src="@drawable/img_nutrition"/>
            </LinearLayout>

            <!--Card Physical-->
            <LinearLayout
                android:id="@+id/LL_physical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_white_stroke_blue"
                android:gravity="center_vertical"
                android:padding="15dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:paddingEnd="16dp"
                    android:src="@drawable/img_phy_act"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Physical Activity"
                        android:fontFamily="@font/poppins_bold"
                        android:textColor="@color/always_black"
                        android:textSize="21sp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:fontFamily="@font/poppins_med"
                        android:textColor="@color/always_black"
                        android:text="Temukan aktivitas fisik yang cocok untuk Anda."
                        android:textSize="10sp"/>
                </LinearLayout>
            </LinearLayout>

            <!--Card Stress Management-->
            <LinearLayout
                android:id="@+id/LL_stress"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_white_stroke_blue"
                android:gravity="center_vertical"
                android:padding="15dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Stress Management"
                        android:textColor="@color/always_black"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="21sp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Cek kesehatan mental Anda di sini."
                        android:textColor="@color/always_black"
                        android:fontFamily="@font/poppins_med"
                        android:textSize="10sp"/>
                </LinearLayout>

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginStart="16dp"
                    android:src="@drawable/img_mental_wellness"/>
            </LinearLayout>

            <!--Card Rest Pattern-->
            <LinearLayout
                android:id="@+id/LL_rest"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="80dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_white_stroke_blue"
                android:gravity="center_vertical"
                android:padding="15dp"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/img_rest_pattern"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rest Pattern"
                        android:textColor="@color/always_black"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="21sp"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:textColor="@color/always_black"
                        android:text="Cek pola tidur Anda disini"
                        android:fontFamily="@font/poppins_med"
                        android:textSize="10sp"/>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!--Bottom Navigation-->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomnavigate"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:layout_marginStart="30dp"
        android:layout_marginEnd="30dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bottom_background"
        android:elevation="4dp"
        app:itemIconTint="@drawable/bg_selector2"
        app:itemRippleColor="@android:color/transparent"
        app:labelVisibilityMode="unlabeled"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:menu="@menu/bottom_menu"/>
</androidx.constraintlayout.widget.ConstraintLayout>