<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".Auth.LoginActivity"
    android:background="@color/white">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="20dp"
            android:paddingBottom="20dp">

            <!-- selamat datang kembali  -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Selamat Datang \nKembali!"
                android:textColor="@color/black"
                android:layout_gravity="start"
                android:layout_marginStart="40dp"
                android:textSize="35sp"
                android:fontFamily="@font/poppins_bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:layout_gravity="start"
                android:layout_marginStart="40dp"
                android:fontFamily="@font/poppins_med"
                android:text="Lanjutkan perjalanan hidup sehatmu!"
                android:textColor="@color/black"
                android:textSize="15sp" />

            <!-- Input Email -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_med"
                android:text="Email"
                android:layout_marginStart="40dp"
                android:layout_gravity="start"
                android:layout_marginTop="45dp"
                android:layout_marginBottom="0dp"
                android:textColor="@color/black"
                android:textSize="15sp" />

            <EditText
                android:id="@+id/eT_email_login"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginStart="40dp"
                android:layout_marginTop="0dp"
                android:layout_marginEnd="40dp"
                android:background="@drawable/bg_input_whiteblue"
                android:drawableStart="@drawable/ic_email"
                app:drawableTint="@color/black"
                android:drawablePadding="16dp"
                android:hint="Masukkan Email"
                android:fontFamily="@font/poppins_reg"
                android:inputType="textEmailAddress"
                android:paddingStart="20dp"
                android:textColor="@color/black"
                android:textColorHint="@color/grey"
                android:textSize="13sp" />

            <!-- Input Password -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/poppins_med"
                android:text="Kata Sandi"
                android:layout_marginStart="40dp"
                android:layout_gravity="start"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="0dp"
                android:textColor="@color/black"
                android:textSize="15sp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:background="@drawable/bg_input_whiteblue">

                <EditText
                    android:id="@+id/eT_password_login"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_toStartOf="@id/iv_toggle_password"
                    android:background="@android:color/transparent"
                    android:drawableStart="@drawable/ic_password"
                    android:drawablePadding="16dp"
                    android:fontFamily="@font/poppins_reg"
                    android:hint="Masukkan Kata Sandi"
                    app:drawableTint="@color/black"
                    android:inputType="textPassword"
                    android:paddingStart="20dp"
                    android:paddingEnd="12dp"
                    android:textColor="@color/black"
                    android:textColorHint="@color/grey"
                    android:textSize="13sp"/>

                <ImageView
                    android:id="@+id/iv_toggle_password"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_marginEnd="16dp"
                    android:src="@drawable/ic_eye"
                    android:clickable="true"
                    android:focusable="true"
                    app:tint="@color/black"/>

            </RelativeLayout>

            <!-- Forgot Password -->
            <TextView
                android:id="@+id/tV_forgetPass"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:layout_marginStart="40dp"
                android:layout_marginEnd="40dp"
                android:fontFamily="@font/poppins_reg"
                android:gravity="end"
                android:text="Lupa Kata Sandi?"
                android:textColor="@color/grey"
                android:textSize="10sp" />

            <!-- Login Button -->
            <Button
                android:id="@+id/btn_login"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginStart="40dp"
                android:layout_marginTop="50dp"
                android:layout_marginEnd="40dp"
                android:background="@drawable/bg_btn_green_new"
                android:text="Masuk"
                android:fontFamily="@font/poppins_bold"
                android:textAllCaps="false"
                android:textColor="@color/white"
                android:textSize="20sp" />

            <!--Divider-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="40dp"
                android:layout_marginTop="20dp"
                android:layout_marginEnd="40dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/black"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:text="atau lanjutkan dengan"
                    android:textColor="@color/grey"
                    android:textSize="12sp"
                    android:maxLines="1"
                    android:ellipsize="none"
                    android:fontFamily="@font/poppins_reg"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/black"/>
            </LinearLayout>

            <!--Button Google-->
            <LinearLayout
                android:id="@+id/btn_google_login"
                android:layout_width="110dp"
                android:layout_height="30dp"
                android:layout_marginTop="0dp"
                android:layout_gravity="center_horizontal"
                android:background="@drawable/bg_input_whiteblue"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:src="@drawable/ic_google" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="10dp"
                    android:text="Google"
                    android:textColor="@color/grey"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_reg" />

            </LinearLayout>

            <!-- No Account Register Link -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="32dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Belum punya akun? "
                    android:fontFamily="@font/poppins_reg"
                    android:textColor="@color/grey" />

                <TextView
                    android:id="@+id/tV_daftar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Daftar"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="@color/tab" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>