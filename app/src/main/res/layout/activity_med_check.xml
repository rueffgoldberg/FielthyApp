<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".Feature.Medcheck.MedCheckActivity"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/LinearLayout11"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingBottom="5dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!--Header atas-->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="40dp">

            <ImageView
                android:id="@+id/iV_kembali"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:paddingBottom="5dp"
                android:src="@drawable/ic_backward"
                app:tint="@color/black"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="@font/poppins_bold"
                android:text="Kategori"
                android:textColor="@color/black"
                android:textSize="20sp"/>
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="1dp"
            android:fontFamily="@font/poppins_bold"
            android:text="Med Check"
            android:textColor="@color/black"
            android:textSize="18sp"/>

        <!--Progress-->
        <LinearLayout
            android:id="@+id/progress_medcheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="7dp"
            android:gravity="top|center_horizontal"
            android:orientation="horizontal">

            <!--Step 1-->
            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <View
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:background="@drawable/circle_active"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:fontFamily="@font/poppins_med"
                    android:gravity="center"
                    android:text="Pemeriksaan \nMed Check"
                    android:textColor="@color/grey"
                    android:textSize="10sp"/>
            </LinearLayout>

            <!--Garis-->
            <View
                android:layout_width="96dp"
                android:layout_height="1dp"
                android:layout_marginTop="13dp"
                android:background="@color/blue" />

            <!--Step 2-->
            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:gravity="center_horizontal"
                android:orientation="vertical">

                <View
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:background="@drawable/circle_out"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:fontFamily="@font/poppins_med"
                    android:gravity="center"
                    android:text="Hasil \nPemeriksaan"
                    android:textColor="@color/grey"
                    android:textSize="10sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:id="@+id/sv_med"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/white"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="12dp"
        android:fillViewport="true"
        android:overScrollMode="never"
        app:layout_constraintTop_toBottomOf="@id/LinearLayout11"
        app:layout_constraintBottom_toTopOf="@id/btn_lanjut_hasil"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:id="@+id/LL_menu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="1dp"
            android:paddingBottom="1dp">

            <!--CARD IMT-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_white_stroke_blue"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingTop="13dp"
                android:paddingEnd="14dp"
                android:paddingBottom="13dp"
                android:gravity="center_vertical">

                <!--Header-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!--Icon-->
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_box"
                        android:padding="5dp"
                        android:src="@drawable/ic_monitor_scale"
                        app:tint="@color/black"/>

                    <!--Text-->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Indeks Massa Tubuh (IMT)"
                            android:textSize="17sp"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/always_black"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pantau Keseimbangan berat badan Anda."
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_reg"
                            android:textColor="@color/always_black"/>
                    </LinearLayout>
                </LinearLayout>

                <!--Input Berat Badan-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/eT_beratBadan"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_blue_input"
                        android:hint="Berat Badan"
                        android:fontFamily="@font/poppins_reg"
                        android:inputType="numberDecimal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/grey"
                        android:textSize="12sp"/>

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="kg"
                        android:textColor="@color/always_black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="11sp"/>
                </LinearLayout>

                <!--Input Tinggi Badan-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/eT_tinggiBadan"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_blue_input"
                        android:hint="Tinggi Badan"
                        android:fontFamily="@font/poppins_reg"
                        android:inputType="numberDecimal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/grey"
                        android:textSize="12sp"/>

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="cm"
                        android:textColor="@color/always_black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="11sp"/>
                </LinearLayout>

                <!--Info IMT-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_info"
                        app:tint="@color/black"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="IMT akan di hitung otomatis berdasarkan berat dan tinggi badan."
                        android:fontFamily="@font/poppins_reg"
                        android:justificationMode="inter_word"
                        android:textSize="11sp"
                        android:textColor="@color/always_black"/>
                </LinearLayout>
            </LinearLayout>

            <!--CARD LINGKAR PERUT-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_white_stroke_blue"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingTop="13dp"
                android:paddingEnd="14dp"
                android:paddingBottom="13dp"
                android:gravity="center_vertical">

                <!--Header-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!--Icon-->
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_box"
                        android:padding="5dp"
                        android:src="@drawable/ic_meteran"
                        app:tint="@color/black"/>

                    <!--Text-->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lingkar Perut"
                            android:textSize="17sp"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/always_black"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pantau lemak di area perut Anda."
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_reg"
                            android:textColor="@color/always_black"/>
                    </LinearLayout>
                </LinearLayout>

                <!--Input Lingkar Perut-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/eT_lingkar_perut"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_blue_input"
                        android:hint="Lingkar Perut"
                        android:fontFamily="@font/poppins_reg"
                        android:inputType="numberDecimal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/grey"
                        android:textSize="12sp"/>

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="cm"
                        android:textColor="@color/always_black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="11sp"/>
                </LinearLayout>

                <!--Info Lingkar Perut-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_info"
                        app:tint="@color/black"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Ukur di area perut bagian tengah (sejajar dengan pusar Anda)."
                        android:fontFamily="@font/poppins_reg"
                        android:justificationMode="inter_word"
                        android:textSize="11sp"
                        android:textColor="@color/always_black"/>
                </LinearLayout>
            </LinearLayout>

            <!--CARD TEKANAN DARAH-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_white_stroke_blue"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingTop="13dp"
                android:paddingEnd="14dp"
                android:paddingBottom="13dp"
                android:gravity="center_vertical">

                <!--Header-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!--Icon-->
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_box"
                        android:padding="5dp"
                        android:src="@drawable/ic_darah"
                        app:tint="@color/black"/>

                    <!--Text-->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tekanan Darah"
                            android:textSize="17sp"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/always_black"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cek kondisi tekanan darah Anda."
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_reg"
                            android:textColor="@color/always_black"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:background="@drawable/bg_white_stroke_blue"
                        android:text="Contoh: Tekanan Darah = 130/80 mmHg --> 130 = Sistolik, 80 = Diastolik."
                        android:fontFamily="@font/poppins_reg"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textColor="@color/always_black"
                        android:textSize="9sp"/>
                </LinearLayout>

                <!--Input Tekanan Darah Sistolik-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/eT_sistolik"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_blue_input"
                        android:hint="Tekanan Darah Sistolik"
                        android:fontFamily="@font/poppins_reg"
                        android:inputType="number"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/grey"
                        android:textSize="12sp"/>

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="mmHg"
                        android:textColor="@color/always_black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="11sp"/>
                </LinearLayout>

                <!--Input Tekanan Darah Diastolik-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/eT_diastolik"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_blue_input"
                        android:hint="Tekanan Darah Diastolik"
                        android:fontFamily="@font/poppins_reg"
                        android:inputType="number"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/grey"
                        android:textSize="12sp"/>

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="mmHg"
                        android:textColor="@color/always_black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="11sp"/>
                </LinearLayout>

                <!--Info Tekanan Darah-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_info"
                        app:tint="@color/black"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Masukkan nilai tekanan darah sesuai hasil dari pemeriksaan Anda."
                        android:fontFamily="@font/poppins_reg"
                        android:justificationMode="inter_word"
                        android:textSize="11sp"
                        android:textColor="@color/always_black"/>
                </LinearLayout>
            </LinearLayout>

            <!--CARD GULA DARAH SEWAKTU-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_white_stroke_blue"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingTop="13dp"
                android:paddingEnd="14dp"
                android:paddingBottom="13dp"
                android:gravity="center_vertical">

                <!--Header-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!--Icon-->
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_box"
                        android:padding="5dp"
                        android:src="@drawable/ic_gula_darah"
                        app:tint="@color/black"/>

                    <!--Text-->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Gula Darah Sewaktu"
                            android:textSize="17sp"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/always_black"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pantau kadar gula darah Anda."
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_reg"
                            android:textColor="@color/always_black"/>
                    </LinearLayout>
                </LinearLayout>

                <!--Input Gula Darah-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/eT_gula"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_blue_input"
                        android:hint="Gula Darah"
                        android:fontFamily="@font/poppins_reg"
                        android:inputType="numberDecimal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/grey"
                        android:textSize="12sp"/>

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="mg/dL"
                        android:textColor="@color/always_black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="11sp"/>
                </LinearLayout>

                <!--Info Gula Darah Sewaktu-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_info"
                        app:tint="@color/black"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:text="Ukur minimal 2 jam setelah makan."
                        android:fontFamily="@font/poppins_reg"
                        android:justificationMode="inter_word"
                        android:textSize="11sp"
                        android:textColor="@color/always_black"/>
                </LinearLayout>
            </LinearLayout>

            <!--CARD KOLESTEROL TOTAL-->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="18dp"
                android:background="@drawable/bg_white_stroke_blue"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingTop="13dp"
                android:paddingEnd="14dp"
                android:paddingBottom="13dp"
                android:gravity="center_vertical">

                <!--Header-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!--Icon-->
                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/bg_icon_box"
                        android:padding="5dp"
                        android:src="@drawable/ic_kolesterol"
                        app:tint="@color/black"/>

                    <!--Text-->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Kolesterol Total"
                            android:textSize="17sp"
                            android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/always_black"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cek kadar kolesterol dalam darah Anda."
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_reg"
                            android:textColor="@color/always_black"/>
                    </LinearLayout>
                </LinearLayout>

                <!--Input Gula Darah-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:layout_marginTop="16dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <EditText
                        android:id="@+id/eT_lemak"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/bg_blue_input"
                        android:hint="Kolesterol Total"
                        android:fontFamily="@font/poppins_reg"
                        android:inputType="numberDecimal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textColor="@color/black"
                        android:textColorHint="@color/grey"
                        android:textSize="12sp"/>

                    <TextView
                        android:layout_width="40dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="mg/dL"
                        android:textColor="@color/always_black"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="11sp"/>
                </LinearLayout>

                <!--Info Gula Darah Sewaktu-->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_info"
                        app:tint="@color/black"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
