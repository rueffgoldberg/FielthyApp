<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".Feature.Physical.PanduanBalkeActivity">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="15dp"
            android:paddingStart="15dp"
            android:paddingEnd="15dp">

            <!-- HEADER -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="60dp">

                <ImageView
                    android:id="@+id/iV_kembali"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:layout_centerVertical="true"
                    android:src="@drawable/ic_backward"
                    app:tint="@color/always_black"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"
                    android:text="Panduan Balke Test"
                    android:fontFamily="@font/poppins_extrabold"
                    android:textSize="22sp"
                    android:textColor="@color/black"/>

                <ImageView
                    android:id="@+id/iV_volume"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:background="@drawable/bg_volume"
                    android:padding="8dp"
                    android:src="@drawable/ic_volume"/>
            </RelativeLayout>

            <!-- APA ITU BALKE -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="50dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_white_stroke_blue"
                android:orientation="horizontal"
                android:padding="18dp">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_info"
                    app:tint="@color/black"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Apa itu Balke Test?"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="20sp"
                        android:textColor="@color/grey"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Balke Test adalah tes untuk mengukur daya tahan kardiorespirasi dengan berjalan atau berlari selama 15 menit."
                        android:textColor="@color/grey"
                        android:fontFamily="@font/poppins_reg"
                        android:justificationMode="inter_word"
                        android:textSize="14sp"/>
                </LinearLayout>

            </LinearLayout>

            <!-- JUDUL -->

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:text="Cara Menggunakan Fitur Balke Test"
                android:textColor="@color/tab"
                android:textSize="19sp"
                android:fontFamily="@font/poppins_bold"/>

            <!-- STEP 1 -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_item_white"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/circle_blue"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="@color/black"
                    android:fontFamily="@font/poppins_extrabold"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tekan Start Tracking"
                        android:fontFamily="@font/poppins_bold"
                        android:textSize="16sp"
                        android:textColor="@color/black" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Aktifkan GPS lalu tekan tombol Start Tracking."
                        android:textColor="@color/grey"
                        android:fontFamily="@font/poppins_reg"/>
                </LinearLayout>

            </LinearLayout>

            <!-- STEP 2 -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_item_white"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/circle_blue"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="@color/black"
                    android:fontFamily="@font/poppins_extrabold"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Berjalan atau Berlari 15 Menit"
                        android:textStyle="bold"
                        android:textSize="16sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_bold"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Lakukan aktivitas selama 15 menit secara konsisten."
                        android:textColor="@color/grey"
                        android:fontFamily="@font/poppins_reg"/>
                </LinearLayout>
            </LinearLayout>

            <!-- STEP 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_item_white"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/circle_blue"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="@color/black"
                    android:fontFamily="@font/poppins_extrabold"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Selesaikan Tes"
                        android:textSize="16sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Setelah waktu habis, hentikan aktivitas."
                        android:textColor="@color/grey"
                        android:fontFamily="@font/poppins_reg"/>
                </LinearLayout>
            </LinearLayout>

            <!-- STEP 4 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_item_white"
                android:orientation="horizontal"
                android:padding="16dp">

                <TextView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/circle_blue"
                    android:gravity="center"
                    android:text="4"
                    android:textColor="@color/black"
                    android:fontFamily="@font/poppins_extrabold"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Lihat Hasil Pemeriksaan"
                        android:textSize="16sp"
                        android:textColor="@color/black"
                        android:fontFamily="@font/poppins_bold"/>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Aplikasi akan menampilkan hasil Balke Test dan estimasi VO₂ Max."
                        android:textColor="@color/grey"
                        android:fontFamily="@font/poppins_reg"/>
                </LinearLayout>
            </LinearLayout>

            <!-- CATATAN -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:background="@drawable/bg_smoker_result_card_berat"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Catatan Penting"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:fontFamily="@font/poppins_bold"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Hentikan tes apabila mengalami pusing, nyeri dada, sesak napas berlebihan, atau kondisi tidak nyaman lainnya."
                    android:textColor="@color/grey"
                    android:fontFamily="@font/poppins_reg"/>
            </LinearLayout>

            <!-- TIPS -->

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_item_white"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tips"
                    android:textColor="@color/black"
                    android:textSize="18sp"
                    android:fontFamily="@font/poppins_bold"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Lakukan pemanasan sebelum memulai dan pendinginan setelah selesai untuk menghindari cedera."
                    android:textColor="@color/grey"
                    android:fontFamily="@font/poppins_reg"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>