<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="@color/white"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/LinearLayoutRestPattern"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingStart="15dp"
        android:paddingEnd="15dp"
        android:paddingTop="5dp"
        android:paddingBottom="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Header atas -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="40dp">

            <ImageView
                android:id="@+id/iV_kembali"
                android:layout_width="38dp"
                android:layout_height="38dp"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:padding="6dp"
                android:src="@drawable/ic_backward"
                app:tint="@color/black" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:fontFamily="@font/poppins_bold"
                android:text="Rest Pattern"
                android:textColor="@color/black"
                android:textSize="20sp" />
        </RelativeLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="12dp"
            android:background="@color/white"
            android:fillViewport="true"
            android:overScrollMode="never"
            app:layout_constraintTop_toBottomOf="@id/LinearLayoutRestPattern"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingBottom="20dp">

                <!-- Status Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="170dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_card_green_soft"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:gravity="center_vertical"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Status Pola Istirahat"
                            android:textColor="@color/black"
                            android:textSize="14sp"
                            android:fontFamily="@font/poppins_bold" />

                        <TextView
                            android:id="@+id/tV_status_pola_istirahat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Baik"
                            android:textColor="@color/tab"
                            android:textSize="34sp"
                            android:fontFamily="@font/poppins_bold" />

                        <TextView
                            android:id="@+id/tV_deskripsi_status_pola_istirahat"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:lineSpacingExtra="2dp"
                            android:text="Pola istirahat Anda konsisten dalam 7 hari terakhir."
                            android:textColor="@color/black"
                            android:textSize="10sp"
                            android:fontFamily="@font/poppins_med"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:background="@drawable/circle_red"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Konsistensi"
                            android:textColor="@color/grey"
                            android:textSize="10sp"
                            android:fontFamily="@font/poppins_bold" />

                        <TextView
                            android:id="@+id/tV_konsistensi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="1dp"
                            android:text="Baik"
                            android:textColor="@color/tab"
                            android:textSize="18sp"
                            android:fontFamily="@font/poppins_extrabold" />

                        <TextView
                            android:id="@+id/tV_selisih"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="Selisih 1 jam"
                            android:textColor="@color/grey"
                            android:fontFamily="@font/poppins_med"
                            android:textSize="10sp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Statistik Row 1 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Total Istirahat -->
                    <LinearLayout
                        android:id="@+id/card_total_istirahat"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_item_white"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Istirahat"
                            android:textColor="@color/red"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_bold"
                            android:layout_gravity="center_horizontal"/>

                        <TextView
                            android:id="@+id/tV_total_istirahat"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="48 jam"
                            android:textColor="@color/black"
                            android:textSize="26sp"
                            android:fontFamily="@font/poppins_extrabold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7 hari terakhir"
                            android:textColor="@color/red"
                            android:textSize="11sp"
                            android:fontFamily="@font/poppins_med" />

                    </LinearLayout>

                    <!-- Jumlah Sesi -->
                    <LinearLayout
                        android:id="@+id/card_jumlah_sesi"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_item_white"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Jumlah Sesi"
                            android:textColor="@color/orange"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_bold"
                            android:layout_gravity="center_horizontal"/>

                        <TextView
                            android:id="@+id/tV_jumlah_sesi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="12 sesi"
                            android:textColor="@color/black"
                            android:textSize="26sp"
                            android:fontFamily="@font/poppins_extrabold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="7 hari terakhir"
                            android:textColor="@color/orange"
                            android:textSize="11sp"
                            android:fontFamily="@font/poppins_med" />

                    </LinearLayout>

                </LinearLayout>

                <!-- Statistik Row 2 -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="horizontal"
                    android:weightSum="2">

                    <!-- Rata-rata Harian -->
                    <LinearLayout
                        android:id="@+id/card_rata_harian"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:background="@drawable/bg_item_white"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rata-rata Harian"
                            android:textColor="@color/tab"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_bold"
                            android:layout_gravity="center_horizontal"/>

                        <TextView
                            android:id="@+id/tV_rata_harian"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="6j 51m"
                            android:textColor="@color/black"
                            android:textSize="26sp"
                            android:fontFamily="@font/poppins_extrabold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="per hari"
                            android:textColor="@color/tab"
                            android:textSize="11sp"
                            android:fontFamily="@font/poppins_med" />

                    </LinearLayout>

                    <!-- Rata-rata Per Sesi -->
                    <LinearLayout
                        android:id="@+id/card_rata_sesi"
                        android:layout_width="0dp"
                        android:layout_height="120dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        android:background="@drawable/bg_item_white"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rata-rata Per Sesi"
                            android:textColor="@color/green2"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_bold"
                            android:layout_gravity="center_horizontal"/>

                        <TextView
                            android:id="@+id/tV_rata_sesi"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="10dp"
                            android:text="4j 20m"
                            android:textColor="@color/black"
                            android:textSize="26sp"
                            android:fontFamily="@font/poppins_extrabold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="per sesi"
                            android:textColor="@color/green2"
                            android:textSize="11sp"
                            android:fontFamily="@font/poppins_med" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Chart Card -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="230dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_item_white"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Aktivitas Istirahat 7 Hari Terakhir"
                        android:textColor="@color/grey"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_bold"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_marginTop="12dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="30dp"
                            android:layout_height="match_parent"
                            android:orientation="vertical">

                            <TextView style="@style/ChartLabel" android:text="10 jam" android:fontFamily="@font/poppins_thin"/>
                            <TextView style="@style/ChartLabel" android:text="8 jam" android:fontFamily="@font/poppins_thin"/>
                            <TextView style="@style/ChartLabel" android:text="6 jam" android:fontFamily="@font/poppins_thin"/>
                            <TextView style="@style/ChartLabel" android:text="4 jam" android:fontFamily="@font/poppins_thin"/>
                            <TextView style="@style/ChartLabel" android:text="2 jam" android:fontFamily="@font/poppins_thin"/>
                            <TextView style="@style/ChartLabel" android:text="0" android:fontFamily="@font/poppins_thin"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="bottom"
                            android:orientation="horizontal"
                            android:weightSum="7">

                            <LinearLayout style="@style/BarColumn">
                                <TextView android:id="@+id/tV_sen" style="@style/BarValue" android:text="7j 50m" android:fontFamily="@font/poppins_reg" />
                                <View android:id="@+id/bar_sen" android:layout_width="18dp" android:layout_height="104dp" android:background="@drawable/bg_bar" />
                                <TextView style="@style/DayLabel" android:text="Sen" />
                            </LinearLayout>

                            <LinearLayout style="@style/BarColumn">
                                <TextView android:id="@+id/tV_sel" style="@style/BarValue" android:text="8j 00m" android:fontFamily="@font/poppins_reg" />
                                <View android:id="@+id/bar_sel" android:layout_width="18dp" android:layout_height="112dp" android:background="@drawable/bg_bar" />
                                <TextView style="@style/DayLabel" android:text="Sel" />
                            </LinearLayout>

                            <LinearLayout style="@style/BarColumn">
                                <TextView android:id="@+id/tV_rab" style="@style/BarValue" android:text="7j 20m" android:fontFamily="@font/poppins_reg"/>
                                <View android:id="@+id/bar_rab" android:layout_width="18dp" android:layout_height="96dp" android:background="@drawable/bg_bar" />
                                <TextView style="@style/DayLabel" android:text="Rab" />
                            </LinearLayout>

                            <LinearLayout style="@style/BarColumn">
                                <TextView android:id="@+id/tV_kam" style="@style/BarValue" android:text="8j 10m" android:fontFamily="@font/poppins_reg"/>
                                <View android:id="@+id/bar_kam" android:layout_width="18dp" android:layout_height="116dp" android:background="@drawable/bg_bar" />
                                <TextView style="@style/DayLabel" android:text="Kam" />
                            </LinearLayout>

                            <LinearLayout style="@style/BarColumn">
                                <TextView android:id="@+id/tV_jum" style="@style/BarValue" android:text="7j 00m" android:fontFamily="@font/poppins_reg"/>
                                <View android:id="@+id/bar_jum" android:layout_width="18dp" android:layout_height="88dp" android:background="@drawable/bg_bar" />
                                <TextView style="@style/DayLabel" android:text="Jum" />
                            </LinearLayout>

                            <LinearLayout style="@style/BarColumn">
                                <TextView android:id="@+id/tV_sab" style="@style/BarValue" android:text="8j 20m" android:fontFamily="@font/poppins_reg"/>
                                <View android:id="@+id/bar_sab" android:layout_width="18dp" android:layout_height="120dp" android:background="@drawable/bg_bar" />
                                <TextView style="@style/DayLabel" android:text="Sab" />
                            </LinearLayout>

                            <LinearLayout style="@style/BarColumn">
                                <TextView android:id="@+id/tV_min" style="@style/BarValue" android:text="7j 30m" android:fontFamily="@font/poppins_reg"/>
                                <View android:id="@+id/bar_min" android:layout_width="18dp" android:layout_height="100dp" android:background="@drawable/bg_bar" />
                                <TextView style="@style/DayLabel" android:text="Min" />
                            </LinearLayout>

                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Kategori Konsistensi -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_item_white"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kategori Konsistensi (Selisih harian)"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_bold" />

                    <!-- Baik -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="●  Baik"
                            android:textColor="@color/green"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_med"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selisih ≤ 2 jam"
                            android:textColor="@color/green"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_med"/>

                    </LinearLayout>

                    <!-- Cukup -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="●  Cukup"
                            android:textColor="@color/orange"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_med"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selisih > 2 - 4 jam"
                            android:textColor="@color/orange"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_med"/>

                    </LinearLayout>

                    <!-- Kurang -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="●  Kurang"
                            android:textColor="@color/red"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_med"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selisih > 4 jam"
                            android:textColor="@color/red"
                            android:textSize="12sp"
                            android:fontFamily="@font/poppins_med"/>
                    </LinearLayout>
                </LinearLayout>

                <!-- Insight -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="118dp"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_item_white"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Insight"
                        android:textColor="@color/black"
                        android:textSize="14sp"
                        android:fontFamily="@font/poppins_bold" />

                    <TextView
                        android:id="@+id/tV_insight"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:lineSpacingExtra="3dp"
                        android:text="Pola istirahat Anda cukup konsisten selama 7 hari terakhir. Pertahankan kebiasaan istirahat yang baik untuk mendukung pemulihan tubuh."
                        android:textColor="@color/grey"
                        android:fontFamily="@font/poppins_reg"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>
        </ScrollView>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>