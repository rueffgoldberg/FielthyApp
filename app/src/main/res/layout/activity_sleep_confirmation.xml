<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#99000000">

    <!-- Pop-up Card centered perfectly -->
    <androidx.cardview.widget.CardView
        android:layout_width="320dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardCornerRadius="20dp"
        app:cardElevation="10dp"
        app:cardBackgroundColor="@android:color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="28dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Konfirmasi Bangun"
                android:textColor="#2BA978"
                android:textSize="20sp"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tv_sleep_question"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Apakah Anda baru saja tidur?"
                android:textColor="@color/always_black"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_reg"
                android:gravity="center"
                android:layout_marginBottom="12dp" />

            <TextView
                android:id="@+id/tv_sleep_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Durasi: - "
                android:textColor="@color/always_black"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_bold"
                android:layout_marginBottom="32dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="2">

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_sleep_no"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:text="TIDAK"
                    android:backgroundTint="#FF5252"
                    android:textColor="@android:color/white"
                    android:layout_marginEnd="10dp"
                    android:fontFamily="@font/poppins_bold"
                    android:textSize="16sp" />

                <androidx.appcompat.widget.AppCompatButton
                    android:id="@+id/btn_sleep_yes"
                    android:layout_width="0dp"
                    android:layout_height="55dp"
                    android:layout_weight="1"
                    android:text="YA"
                    android:backgroundTint="#2BA978"
                    android:textColor="@android:color/white"
                    android:layout_marginStart="10dp"
                    android:textSize="16sp"
                    android:fontFamily="@font/poppins_bold" />
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>