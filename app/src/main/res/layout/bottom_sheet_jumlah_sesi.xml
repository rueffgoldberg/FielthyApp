<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Handle -->
        <View
            android:layout_width="50dp"
            android:layout_height="5dp"
            android:layout_gravity="center"
            android:background="@color/grey" />

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Jumlah Sesi Istirahat"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_bold" />

            <ImageView
                android:id="@+id/iV_close_jumlah_sesi"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_x"
                app:tint="@color/black"/>
        </LinearLayout>

        <!-- Tanggal -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_calendar" />

            <TextView
                android:id="@+id/tV_tanggal_sesi"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="20 Juni 2026"
                android:textColor="@color/black"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_med" />
        </LinearLayout>

        <!-- Tanggal -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="Rincian Sesi"
            android:textColor="@color/black"
            android:textSize="15sp"
            android:fontFamily="@font/poppins_bold" />

        <LinearLayout
            android:id="@+id/layout_sesi_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

        <!-- Penjelasan -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_item_white"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tentang Sesi Istirahat"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_bold"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Jumlah sesi menunjukkan berapa kali sistem mendeteksi periode istirahat yang tersimpan dalam satu hari. Satu hari dapat memiliki lebih dari satu sesi istirahat."
                android:textColor="@color/grey"
                android:textSize="12sp"/>
        </LinearLayout>

        <!-- Ringkasan -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:background="@drawable/bg_item_white"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Sesi"
                android:textColor="@color/black"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:id="@+id/tV_total_sesi_bottomsheet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12 sesi"
                android:textColor="@color/tab"
                android:textSize="30sp"
                android:fontFamily="@font/poppins_extrabold" />

            <TextView
                android:id="@+id/tV_detail_sesi_bottomsheet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Utama 4 • Pendek 6 • Mikro 2"
                android:textColor="@color/grey"
                android:textSize="12sp"
                android:layout_marginTop="6dp"/>
        </LinearLayout>

    </LinearLayout>

</ScrollView>