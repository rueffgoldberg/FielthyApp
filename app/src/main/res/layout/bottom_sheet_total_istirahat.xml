<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="true"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Total Istirahat Anda"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_bold" />

            <ImageView
                android:id="@+id/iV_close_total_istirahat"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_x"
                app:tint="@color/black"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="7 Hari Terakhir"
            android:textColor="@color/black"
            android:textSize="12sp"
            android:fontFamily="@font/poppins_med" />

        <!-- Summary Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/bg_item_white"
            android:orientation="vertical"
            android:padding="18dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Total Durasi Istirahat"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:id="@+id/tV_total_bottomsheet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="52 jam 30 menit"
                android:textColor="@color/tab"
                android:textSize="34sp"
                android:fontFamily="@font/poppins_extrabold" />
        </LinearLayout>

        <!-- Rincian Per Hari -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="Rincian per Hari"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:fontFamily="@font/poppins_bold" />

        <LinearLayout
            android:id="@+id/layout_hari_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"/>

        <!-- Insight Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_item_white"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Insight"
                android:textColor="@color/black"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:id="@+id/tV_insight_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Bagus!"
                android:textColor="@color/tab"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_bold" />

            <TextView
                android:id="@+id/tV_insight_desc"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Total istirahat Anda berada dalam rentang yang baik. Pertahankan pola istirahat yang konsisten."
                android:textColor="@color/grey"
                android:textSize="12sp"
                android:fontFamily="@font/poppins_med" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>