<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@color/white">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Rata-rata Harian"
            android:textColor="@color/black"
            android:textSize="28sp"
            android:fontFamily="@font/poppins_bold" />

        <ImageView
            android:id="@+id/iV_close_rata_harian"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_x"
            app:tint="@color/black"/>
    </LinearLayout>

    <!-- PERIODE -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_calendar"
            app:tint="@color/black"/>

        <TextView
            android:id="@+id/tV_periode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="7 Hari Terakhir"
            android:textColor="@color/grey"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_med" />
    </LinearLayout>

    <!-- CARD -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="28dp"
        android:gravity="center_vertical">

        <!-- TOTAL ISTIRAHAT -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="130dp"
            android:layout_weight="1"
            android:background="@drawable/bg_item_white"
            android:orientation="vertical"
            android:padding="16dp">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_item_white"
                android:padding="10dp"
                android:src="@drawable/ic_moon" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Total Istirahat"
                android:maxLines="1"
                android:ellipsize="end"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_med" />

            <TextView
                android:id="@+id/tV_total_istirahat_popup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="52j 30m"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_bold" />

        </LinearLayout>

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="÷"
            android:textColor="@color/black"
            android:textSize="26sp"
            android:textStyle="bold" />

        <!-- PERIODE -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="130dp"
            android:layout_weight="1"
            android:background="@drawable/bg_item_white"
            android:orientation="vertical"
            android:padding="16dp">

            <ImageView
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_item_white"
                android:padding="10dp"
                android:src="@drawable/ic_calendar"
                app:tint="@color/black"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Periode"
                android:textColor="@color/black"
                android:textSize="13sp"
                android:fontFamily="@font/poppins_med" />

            <TextView
                android:id="@+id/tV_periode_popup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7 hari"
                android:textColor="@color/black"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_bold" />

        </LinearLayout>

    </LinearLayout>

    <!-- PERHITUNGAN -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="30dp"
        android:text="Perhitungan"
        android:textColor="@color/grey"
        android:textSize="15sp"
        android:fontFamily="@font/poppins_med" />

    <TextView
        android:id="@+id/tV_rumus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:text="52j 30m ÷ 7 ="
        android:textColor="@color/grey"
        android:textSize="22sp"
        android:fontFamily="@font/poppins_bold" />

    <!-- HASIL -->
    <TextView
        android:id="@+id/tV_hasil_rata_harian"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="6j 51m"
        android:textColor="@color/tab"
        android:textSize="52sp"
        android:fontFamily="@font/poppins_extrabold" />

    <!-- KATEGORI -->
    <LinearLayout
        android:id="@+id/layoutKategori"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:layout_marginTop="10dp"
        android:background="@drawable/bg_white_stroke_blue"
        android:paddingHorizontal="30dp"
        android:paddingVertical="10dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kategori: "
            android:textColor="@color/always_black"
            android:textSize="16sp"
            android:fontFamily="@font/poppins_bold" />

        <TextView
            android:id="@+id/tV_kategori"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cukup"
            android:textColor="#F4B400"
            android:textSize="16sp"
            android:fontFamily="@font/poppins_bold" />
    </LinearLayout>

    <!-- INFO -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/bg_item_white"
        android:gravity="center_vertical"
        android:padding="16dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_info" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_weight="1"
            android:text="Rata-rata durasi istirahat Anda per hari dalam 7 hari terakhir."
            android:textColor="@color/grey"
            android:textSize="14sp"
            android:fontFamily="@font/poppins_med" />

    </LinearLayout>

</LinearLayout>